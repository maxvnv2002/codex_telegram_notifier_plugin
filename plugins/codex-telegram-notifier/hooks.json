{
  "description": "Send a Telegram notification when Codex stops.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/codex-telegram-notifier.mjs\" notify",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
